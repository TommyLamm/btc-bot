# BTC Bot runtime environment example
# Copy to one of:
#   /etc/default/btcbot
#   /etc/btcbot.env
#   /root/btc-bot/.env
#
# Keep this file private and chmod 600 when storing real secrets.

HL_ENABLED=true

# Private key (use one name only; HL_SECRET is preferred)
HL_SECRET=0xYOUR_PRIVATE_KEY
# HL_SECRET_KEY=0xYOUR_PRIVATE_KEY

# Account address (use one name only; HL_ACCOUNT is preferred)
HL_ACCOUNT=0xYOUR_ACCOUNT_ADDRESS
# HL_ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS

# Trading params
HL_LEVERAGE=3
HL_ACCOUNT_SIZE=400
BASE_POSITION_USD=200
MIN_POSITION_USD=50
MAX_POSITION_USD=350
TARGET_PROFIT=2.0

# Strategy toggles
ENABLE_OI_FACTORS=false
SIGNAL_DEBUG=true
